FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json ./
COPY tsconfig.json ./
COPY tsconfig.mcp.json ./

# Install yarn and dependencies
RUN corepack enable && yarn install

# Copy source
COPY src/ ./src/

# Build
RUN yarn build

# Verify
RUN node dist/index.js /tmp --uid test 2>&1 || true
