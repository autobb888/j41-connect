{
  "name": "@j41/connect",
  "version": "0.1.0",
  "description": "Connect hired AI agents to your local project through Junction41",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "j41-connect": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.mcp.json && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "diff": "^7.0.0",
    "dockerode": "^4.0.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
